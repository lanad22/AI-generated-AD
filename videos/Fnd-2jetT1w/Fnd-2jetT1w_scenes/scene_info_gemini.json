        ],
        "captions": [],
        "audio_clips": [
            {
                "start_time": 0.0,
                "type": "Text on Screen",
                "text": "CONCLUSION"
            },
            {
                "start_time": 0.0,
                "type": "Text on Screen",
                "text": "OR CHANGES DEPENDING ON THE PRESSURE APPLIED TO IT, IT'S A NON-NEWTONIAN FLUID."
            },
            {
                "start_time": 0.0,
                "type": "Visual",
                "text": "Purple screen with text."
