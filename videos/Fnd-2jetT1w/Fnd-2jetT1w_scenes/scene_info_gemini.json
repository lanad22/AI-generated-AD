        ]
    },
    {
        "scene_number": 20,
        "start_frame": 3812,
        "end_frame": 3977,
        "start_time": 158.99216666666666,
        "end_time": 165.87404166666664,
        "duration": 6.8818749999999795,
        "scene_path": "videos/Fnd-2jetT1w/Fnd-2jetT1w_scenes/scene_020.mp4",
        "transcript": [
            {
                "text": "Our oobleck is a non-Newtonian substance with a pretty simple recipe.",
                "start": 0.0,
                "end": 3.6
            },
            {
                "text": "No magical kings required.",
                "start": 3.64,
                "end": 5.4
            },
            {
                "text": "All you need is about one...",
                "start": 5.4,
                "end": 6.86
            }
        ],
        "captions": [],
        "audio_clips": [
            {
                "start_time": 0.0,
                "type": "Visual",
                "text": "Sabrina sits at a desk and speaks to the camera."
            }
        ]
    },
    {
        "scene_number": 21,
        "start_frame": 3978,
        "end_frame": 4096,
        "start_time": 165.91574999999997,
        "end_time": 170.83733333333333,
        "duration": 4.921583333333359,
        "scene_path": "videos/Fnd-2jetT1w/Fnd-2jetT1w_scenes/scene_021.mp4",
        "transcript": [
            {
                "text": "and a half cups of cornstarch, about one cup of water, a big bowl and a spoon.",
                "start": 0.0,
                "end": 4.74
            }
        ],
        "captions": [],
        "audio_clips": [
            {
                "start_time": 0.0,
                "type": "Text on Screen",
                "text": "1 1/2 C. CORNSTARCH"
