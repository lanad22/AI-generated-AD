        "start_time": 139.1807083333333,
        "end_time": 152.69420833333334,
        "duration": 13.513500000000022,
        "scene_path": "videos/Fnd-2jetT1w/Fnd-2jetT1w_scenes/scene_018.mp4",
        "transcript": [
            {
                "text": "Believe it or not, I didn't make this word up.",
                "start": 0.0,
                "end": 1.82
            },
            {
                "text": "It comes from a book written by Dr. Seuss.",
                "start": 1.82,
                "end": 3.82
            },
            {
                "text": "You know, the guy who wrote The Cat in the Hat?",
                "start": 3.82,
                "end": 5.6
            },
            {
                "text": "In another book he wrote called Bartholomew and the Oobleck,",
                "start": 5.6,
                "end": 8.08
            },
            {
                "text": "there's a king who gets bored with normal, everyday weather,",
                "start": 8.08,
                "end": 10.62
            },
            {
                "text": "so instead he makes sticky stuff fall from the sky.",
                "start": 10.62,
                "end": 13.12
            },
            {
                "text": "That-",
                "start": 13.12,
                "end": 13.5
            }
        ],
        "captions": [],
        "audio_clips": [
            {
                "start_time": 0.0,
                "type": "Text on Screen",
                "text": "OOBLECK"
            },
            {
                "start_time": 0.0,
