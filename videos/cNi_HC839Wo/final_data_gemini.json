    },
    {
      "start_time": 94.64120833333334,
      "end_time": 97.48120833333334,
      "duration": 2.94,
      "audio_text": "We're afraid that we will never escape our past.",
      "sequence_num": 42
    },
    {
      "start_time": 97.58120833333334,
      "end_time": 99.38120833333333,
      "duration": 1.9,
      "audio_text": "Whatever we give you, it's never enough.",
      "sequence_num": 43
    },
    {
      "start_time": 99.48120833333333,
      "end_time": 100.38120833333333,
      "duration": 1.0,
      "audio_text": "It's never enough.",
