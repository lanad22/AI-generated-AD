      "end_time": 42.536633333333334,
      "duration": 2.26,
      "audio_text": "Bald eagles are found in North America.",
      "sequence_num": 7
    },
    {
      "start_time": 43.98663333333333,
      "end_time": 46.94663333333333,
      "duration": 3.06,
      "audio_text": "They're the national animal of the United States of America.",
