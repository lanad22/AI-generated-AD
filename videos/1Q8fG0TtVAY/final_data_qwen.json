{
  "dialogue_timestamps": [
    {
      "start_time": 3.85,
      "end_time": 6.03,
      "duration": 2.28,
      "audio_text": "I used to want to save the world.",
      "sequence_num": 1
    },
    {
      "start_time": 11.636624999999999,
      "end_time": 22.916624999999996,
      "duration": 11.38,
      "audio_text": "this beautiful place but the closer you get the more you see the great darkness within",
      "sequence_num": 2
    },
    {
      "start_time": 38.33283333333333,
      "end_time": 41.57283333333333,
      "duration": 3.34,
      "audio_text": "I learned this the hard way, a long, long time ago.",
      "sequence_num": 3
    },
    {
      "start_time": 47.50016666666666,
      "end_time": 48.50016666666666,
      "duration": 1.1,
      "audio_text": "What is your mission?",
      "sequence_num": 4
    },
    {
      "start_time": 48.60016666666666,
      "end_time": 49.72016666666666,
      "duration": 1.22,
      "audio_text": "To stop the war.",
      "sequence_num": 5
    },
    {
      "start_time": 49.82016666666666,
      "end_time": 50.66016666666666,
      "duration": 0.94,
      "audio_text": "What war?",
      "sequence_num": 6
    },
    {
      "start_time": 50.76016666666666,
      "end_time": 52.74016666666666,
      "duration": 2.08,
      "audio_text": "The war to end all wars.",
      "sequence_num": 7
    },
    {
      "start_time": 55.24495833333333,
      "end_time": 55.94495833333333,
      "duration": 0.8,
      "audio_text": "Weapons.",
      "sequence_num": 8
    },
    {
      "start_time": 55.88916666666666,
      "end_time": 57.60916666666666,
      "duration": 1.82,
      "audio_text": "far deadlier than you can ever imagine.",
      "sequence_num": 9
    },
    {
      "start_time": 59.03916666666666,
      "end_time": 60.00916666666666,
      "duration": 1.07,
      "audio_text": "The wall can be ours.",
      "sequence_num": 10
    },
    {
      "start_time": 62.202,
      "end_time": 65.14200000000001,
      "duration": 3.04,
      "audio_text": "Whoever you are, you are in more danger than you think.",
      "sequence_num": 11
    },
    {
      "start_time": 65.48208333333334,
      "end_time": 67.74208333333334,
      "duration": 2.36,
      "audio_text": "I cannot stand by while innocent lives are lost.",
      "sequence_num": 12
    },
    {
      "start_time": 70.90208333333334,
      "end_time": 72.03208333333335,
      "duration": 1.23,
      "audio_text": "Be careful, Diana.",
      "sequence_num": 13
    },
    {
      "start_time": 73.59208333333333,
      "end_time": 76.36595833333332,
      "duration": 2.77,
      "audio_text": "Who is this?",
      "sequence_num": 14
    },
    {
      "start_time": 76.951875,
      "end_time": 81.231875,
      "duration": 4.38,
      "audio_text": "Sir, she's a very good secretary.",
      "sequence_num": 15
    },
    {
      "start_time": 85.28470833333333,
      "end_time": 89.64470833333334,
      "duration": 4.46,
      "audio_text": "It is our sacred duty to defend the world and it's what I'm going to do",
      "sequence_num": 16
    },
    {
      "start_time": 131.725875,
      "end_time": 133.905875,
      "duration": 2.28,
      "audio_text": "How can a woman possibly fight in this?",
      "sequence_num": 17
    },
    {
      "start_time": 134.725875,
      "end_time": 136.605875,
      "duration": 1.98,
      "audio_text": "We use our principles.",
      "sequence_num": 18
    },
    {
      "start_time": 137.137,
      "end_time": 140.39700000000002,
      "duration": 3.36,
      "audio_text": "Although I am not opposed to engaging in a bit of fisticuffs.",
      "sequence_num": 19
    },
    {
      "start_time": 140.72391666666667,
      "end_time": 141.84391666666667,
      "duration": 1.22,
      "audio_text": "should the occasion arise.",
      "sequence_num": 20
    }
  ],
