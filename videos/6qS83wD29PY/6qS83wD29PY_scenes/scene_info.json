    "duration": 2.799999999999999,
    "scene_path": "videos/6qS83wD29PY/6qS83wD29PY_scenes/scene_005.mp4",
    "transcript": [
      {
        "text": "But right now, the best guess seems to be that our brains contain around 80% of the",
        "start": 0.0,
        "end": 2.82
      }
    ],
    "captions": []
  },
  {
    "scene_number": 6,
    "start_frame": 368,
    "end_frame": 417,
    "start_time": 14.72,
